    "friends.empty.description": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir davet linki gönder; arkadaşın kabul edince günlük özeti burada görünür."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send an invite link; once your friend accepts, their daily summary will appear here."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أرسل رابط دعوة؛ وعندما يقبل صديقك، سيظهر ملخصه اليومي هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sende einen Einladungslink; sobald die Einladung angenommen wird, erscheint die Tageszusammenfassung hier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía un enlace de invitación; cuando tu amigo acepte, su resumen diario aparecerá aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyez un lien d'invitation ; dès que votre ami accepte, son résumé quotidien apparaît ici."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक आमंत्रण लिंक भेजें; आपके दोस्त के स्वीकार करते ही उसकी दैनिक समरी यहाँ दिखेगी।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirim tautan undangan; setelah temanmu menerima, ringkasan hariannya akan muncul di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia un link di invito; quando il tuo amico accetta, il suo riepilogo giornaliero apparirà qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "招待リンクを送りましょう。友達が承認すると、その友達の毎日のサマリーがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "초대 링크를 보내 보세요. 친구가 수락하면 친구의 하루 요약이 여기에 표시돼요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuur een uitnodigingslink; zodra je vriend accepteert, verschijnt de dagelijkse samenvatting hier."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyślij link z zaproszeniem; gdy znajomy je przyjmie, jego dzienne podsumowanie pojawi się tutaj."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Envie um link de convite; quando seu amigo aceitar, o resumo diário dele aparecerá aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправьте ссылку-приглашение; когда друг примет её, его ежедневная сводка появится здесь."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ส่งลิงก์คำเชิญ เมื่อเพื่อนตอบรับ สรุปประจำวันของเขาจะแสดงที่นี่"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надішліть посилання-запрошення; коли друг прийме його, тут з'явиться його щоденний підсумок."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gửi một liên kết mời; khi bạn của bạn chấp nhận, tóm tắt hằng ngày của họ sẽ hiển thị ở đây."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送一个邀请链接；朋友接受后，其每日摘要会显示在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "傳送一個邀請連結；朋友接受後，其每日摘要會顯示在這裡。"
          }
        }
      }
    },
