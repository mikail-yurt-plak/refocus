    "Kişiye özel odak ve zaman yönetimi asistanı": {},
    "method.description.deep_work": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عمل عميق بدون انقطاع. مثالي للمهام المعقدة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ununterbrochene Tiefenarbeit. Ideal für komplexe Aufgaben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninterrupted deep work. Ideal for complex tasks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Trabajo profundo sin interrupciones. Ideal para tareas complejas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Travail profond sans interruption. Idéal pour les tâches complexes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निर्बाध गहन कार्य। जटिल कार्यों के लिए आदर्श।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pekerjaan mendalam tanpa gangguan. Ideal untuk tugas kompleks."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lavoro profondo senza interruzioni. Ideale per compiti complessi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "中断のないディープワーク。複雑なタスクに最適。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "중단 없는 딥 워크. 복잡한 작업에 이상적입니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ononderbroken diep werk. Ideaal voor complexe taken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nieprzerwana głęboka praca. Idealna do złożonych zadań."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Trabalho profundo sem interrupções. Ideal para tarefas complexas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Непрерывная глубокая работа. Идеально для сложных задач."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ทำงานลึกโดยไม่ถูกขัดจังหวะ เหมาะสำหรับงานที่ซับซ้อน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kesintisiz derin çalışma. Karmaşık görevler için ideal."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Безперервна глибока робота. Ідеально для складних завдань."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Làm việc sâu không gián đoạn. Lý tưởng cho các nhiệm vụ phức tạp."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不间断的深度工作。适合复杂任务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不間斷的深度工作。適合複雜任務。"
          }
        }
      }
    },
    "method.description.extended": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أطول قليلاً من بومودورو. للتركيز العميق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas länger als Pomodoro. Für tiefere Fokusarbeit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A bit longer than Pomodoro. For deeper focus work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un poco más largo que Pomodoro. Para un enfoque más profundo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un peu plus long que Pomodoro. Pour une concentration plus profonde."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पोमोडोरो से थोड़ा लंबा। गहरे फोकस कार्य के लिए।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sedikit lebih lama dari Pomodoro. Untuk pekerjaan fokus yang lebih dalam."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un po' più lungo del Pomodoro. Per un lavoro di concentrazione più profondo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ポモドーロより少し長め。より深い集中作業に。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "포모도로보다 약간 더 깁니다. 더 깊은 집중 작업을 위해."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Iets langer dan Pomodoro. Voor dieper focuswerk."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Trochę dłużej niż Pomodoro. Do głębszej pracy skupienia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um pouco mais longo que o Pomodoro. Para um foco mais profundo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Немного дольше Помодоро. Для более глубокой работы."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยาวกว่าโปโมโดโรเล็กน้อย สำหรับงานที่ต้องโฟกัสลึกขึ้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pomodoro'dan biraz daha uzun. Daha derinlemesine odaklanmak için."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Трохи довше за Помодоро. Для глибшої зосередженої роботи."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dài hơn Pomodoro một chút. Để tập trung sâu hơn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "比番茄工作法稍长。适合更深入的专注工作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "比番茄工作法稍長。適合更深入的專注工作。"
          }
        }
      }
    },
    "method.description.optimal": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدة تركيز مثالية مدعومة بالأبحاث. متوازنة ومستدامة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Forschungsgestützte optimale Fokuszeit. Ausgewogen und nachhaltig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Research-backed optimal focus duration. Balanced and sustainable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Duración de enfoque óptima respaldada por investigaciones. Equilibrada y sostenible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée de concentration optimale basée sur la recherche. Équilibrée et durable."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शोध-समर्थित इष्टतम फोकस अवधि। संतुलित और टिकाऊ।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Durasi fokus optimal berdasarkan penelitian. Seimbang dan berkelanjutan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Durata di concentrazione ottimale basata sulla ricerca. Equilibrata e sostenibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "研究に基づく最適な集中時間。バランスが取れて持続可能。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연구 기반의 최적 집중 시간. 균형 잡히고 지속 가능합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door onderzoek ondersteunde optimale focusduur. Gebalanceerd en duurzaam."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Optymalny czas skupienia poparty badaniami. Zrównoważony i trwały."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Duração de foco ideal baseada em pesquisas. Equilibrada e sustentável."
          }
        },
        "ru": {
