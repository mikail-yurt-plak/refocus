    "break.suggestion.breathe.description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe in for 4 seconds, hold for 4, breathe out for 4.\nRepeat 3-4 times."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "4 saniye nefes al, 4 saniye tut, 4 saniye ver.\nBunu 3-4 kez tekrarla."
          }
        }
      }
    },
    "break.suggestion.breathe.title": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a Deep Breath"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Derin Nefes Al"
          }
        }
      }
    },
    "break.suggestion.eyes.description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look at something 20 meters away for 20 seconds.\nReduce screen fatigue."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "20 saniye boyunca 20 metre uzağa bak.\nEkran yorgunluğunu azalt."
          }
        }
      }
    },
    "break.suggestion.eyes.title": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rest Your Eyes"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gözlerini Dinlendir"
          }
        }
      }
    },
    "break.suggestion.stretch.description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Do neck, shoulder and back stretches.\nRelax your muscles."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boyun, omuz ve sırt germe hareketleri yap.\nKaslarını gevşet."
          }
        }
      }
    },
    "break.suggestion.stretch.title": {
      "extractionState": "stale",
