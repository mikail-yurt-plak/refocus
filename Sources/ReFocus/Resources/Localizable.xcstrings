          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa persona non potrà più vedere il tuo riepilogo. Vuoi continuare?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この人はあなたのサマリーを見られなくなります。続けますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 사람은 더 이상 내 요약을 볼 수 없게 돼요. 계속할까요?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze persoon kan je samenvatting dan niet meer zien. Doorgaan?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta osoba nie będzie już widzieć Twojego podsumowania. Kontynuować?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa pessoa não poderá mais ver seu resumo. Continuar?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот человек больше не сможет видеть твою сводку. Продолжить?"
