    "break.suggestion.deep_breath.description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استنشق لمدة 4 ثوانٍ، احبس النفس 4، ثم ازفر 4.\nكرر 3-4 مرات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "4 Sekunden einatmen, 4 halten, 4 ausatmen.\n3-4 Mal wiederholen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe in for 4 seconds, hold for 4, breathe out for 4.\nRepeat 3-4 times."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inhala 4 segundos, mantén 4, exhala 4.\nRepite 3-4 veces."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Inspirez 4 secondes, retenez 4, expirez 4.\nRépétez 3-4 fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "4 सेकंड सांस लें, 4 रोकें, 4 में छोड़ें।\n3-4 बार दोहराएं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarik napas 4 detik, tahan 4, hembuskan 4.\nUlangi 3-4 kali."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inspira per 4 secondi, trattieni per 4, espira per 4.\nRipeti 3-4 volte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "4秒吸って、4秒止めて、4秒吐く。\n3〜4回繰り返しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "4초 들이쉬고, 4초 멈추고, 4초 내쉬세요.\n3-4번 반복하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Adem 4 seconden in, houd 4 vast, adem 4 uit.\nHerhaal 3-4 keer."
          }
        },
