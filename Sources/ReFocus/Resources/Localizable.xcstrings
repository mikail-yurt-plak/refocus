        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "พรุ่งนี้ลองเซสชันสั้นๆ ดู"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yarın daha kısa seanslar deneyebilirsin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Завтра можеш спробувати коротші сеанси."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngày mai bạn có thể thử các phiên ngắn hơn."
          }
