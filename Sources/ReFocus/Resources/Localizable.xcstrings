    "workcontext.picker_description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك ربط هذه الجلسة بمجال عمل إذا أردت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du möchtest, kannst du diese Sitzung einem Arbeitsbereich zuordnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can associate this session with a workspace if you like."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si quieres, puedes asociar esta sesión a un área de trabajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous le souhaitez, vous pouvez associer cette session à un espace de travail."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चाहें तो आप इस सत्र को किसी कार्यक्षेत्र से जोड़ सकते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika mau, kamu bisa mengaitkan sesi ini dengan area kerja."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se vuoi, puoi associare questa sessione a un’area di lavoro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "必要であれば、このセッションを作業エリアに関連付けられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원하면 이 세션을 작업 영역과 연결할 수 있어요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als je wilt, kun je deze sessie aan een werkgebied koppelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli chcesz, możesz powiązać tę sesję z obszarem pracy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Se quiser, você pode associar esta sessão a uma área de trabalho."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При желании вы можете связать эту сессию с рабочей областью."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากต้องการ คุณสามารถเชื่อมโยงเซสชันนี้กับพื้นที่ทำงานได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İstersen bu seansı bir çalışma alanıyla ilişkilendirebilirsin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "За бажанням ви можете пов’язати цю сесію з робочою областю."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nếu muốn, bạn có thể liên kết phiên này với một không gian làm việc."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你愿意，可以将此专注与一个工作场景关联。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你願意，可以將此專注與一個工作場景關聯。"
          }
        }
      }
    },
