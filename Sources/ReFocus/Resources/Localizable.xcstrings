          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Besok kamu bisa mencoba sesi yang lebih pendek."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Domani potresti provare sessioni più brevi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "明日は短めのセッションを試してみては。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내일은 더 짧은 세션을 시도해 보세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Morgen kun je kortere sessies proberen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jutro możesz spróbować krótszych sesji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Amanhã você pode tentar sessões mais curtas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Завтра можешь попробовать более короткие сессии."
