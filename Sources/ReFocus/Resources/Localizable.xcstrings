    "friends.invite.note": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Karşılıklı görmek için arkadaşının da sana davet göndermesi gerekir."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To see each other's summaries, your friend needs to send you an invite too."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لكي تريا بعضكما، يحتاج صديقك أيضًا إلى إرسال دعوة إليك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Damit ihr euch gegenseitig sehen könnt, muss dir die andere Person ebenfalls eine Einladung senden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para verse mutuamente, tu amigo también tiene que enviarte una invitación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour vous voir mutuellement, ton ami(e) doit aussi t'envoyer une invitation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक-दूसरे को देखने के लिए आपके दोस्त को भी आपको आमंत्रण भेजना होगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Agar bisa saling melihat, temanmu juga perlu mengirim undangan kepadamu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per vedervi a vicenda, anche il tuo amico deve inviarti un invito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "お互いに見られるようにするには、友達からもあなたに招待を送ってもらう必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "서로의 요약을 보려면 친구도 나에게 초대를 보내야 해요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Om elkaar te kunnen zien, moet je vriend(in) jou ook een uitnodiging sturen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby widzieć się nawzajem, druga osoba również musi wysłać Ci zaproszenie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Para verem um ao outro, seu amigo também precisa enviar um convite para você."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы видеть друг друга, твой друг тоже должен отправить тебе приглашение."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากต้องการเห็นกันและกัน เพื่อนของคุณต้องส่งคำเชิญให้คุณด้วย"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоб бачити одне одного, твій друг також має надіслати тобі запрошення."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Để nhìn thấy nhau, bạn của bạn cũng cần gửi lời mời cho bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要互相查看，朋友也需要向你发送邀请。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "若要互相查看，朋友也需要向你傳送邀請。"
          }
        }
      }
    },
