          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Em que você geralmente trabalha?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Над чем вы обычно работаете?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "普段何に取り組んでいますか？"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Woran arbeitest du normalerweise?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주로 무슨 작업을 하시나요?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn thường làm việc gì?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Su cosa lavori di solito?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nad czym zwykle pracujesz?"
          }
        },
