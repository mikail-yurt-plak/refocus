    "focus.break_message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خذ نفساً عميقاً.\nاستعد للجلسة التالية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Atme durch.\nBereite dich auf die nächste Sitzung vor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a breath.\nPrepare for the next session."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toma un respiro.\nPrepárate para la siguiente sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenez une respiration.\nPréparez-vous pour la prochaine session."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "थोड़ा सांस लें।\nअगले सत्र के लिए तैयार हों।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarik napas.\nBersiap untuk sesi berikutnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai un respiro.\nPreparati per la prossima sessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "深呼吸してください。\n次のセッションの準備をしましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잠시 숨을 고르세요.\n다음 세션을 준비하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Neem even adem.\nBereid je voor op de volgende sessie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weź oddech.\nPrzygotuj się do następnej sesji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Respire fundo.\nPrepare-se para a próxima sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сделайте вдох.\nПодготовьтесь к следующей сессии."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หายใจสักครู่\nเตรียมตัวสำหรับเซสชันถัดไป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Biraz nefes al.\nBir sonraki seansa hazırlan."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зробіть вдих.\nПідготуйтесь до наступної сесії."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hít thở sâu.\nChuẩn bị cho phiên tiếp theo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "深呼吸一下。\n为下一个专注时段做准备。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "深呼吸一下。\n為下一個專注時段做準備。"
          }
        }
      }
    },
