        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir terminer la session maintenant ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या आप वाकई अभी सत्र समाप्त करना चाहते हैं?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Yakin ingin mengakhiri sesi sekarang?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler terminare la sessione ora?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当に今セッションを終了しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 세션을 종료하시겠습니까?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet je zeker dat je de sessie nu wilt beëindigen?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz teraz zakończyć sesję?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja finalizar a sessão agora?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите завершить сессию сейчас?"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณแน่ใจหรือว่าต้องการจบเซสชันตอนนี้?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seansı şimdi bitirmek istediğinden emin misin?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете завершити сесію зараз?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc muốn kết thúc phiên ngay bây giờ không?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你确定要现在结束专注吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你確定要現在結束專注嗎？"
          }
        }
      }
    },
