    "onboarding.context.title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Genellikle ne üzerinde çalışıyorsun?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What do you usually work on?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你通常做什么工作？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你通常做什麼工作？"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप आमतौर पर क्या काम करते हैं?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿En qué sueles trabajar?"
          }
