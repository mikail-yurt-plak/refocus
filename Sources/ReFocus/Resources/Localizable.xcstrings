          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une courte note aide à la fermeture mentale et vous rappelle ce que vous avez fait."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ملاحظة قصيرة توفر الإغلاق الذهني وتساعدك على تذكر ما فعلته."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma nota curta proporciona fechamento mental e ajuda a lembrar o que você fez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткая заметка обеспечивает ментальное завершение и помогает вспомнить, что вы делали."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
