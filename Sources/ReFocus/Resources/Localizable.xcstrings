    "break.suggestion.breathe.title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Derin Nefes Al"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a Deep Breath"
          }
        }
      }
    },
    "break.suggestion.breathe.description": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "4 saniye nefes al, 4 saniye tut, 4 saniye ver.\nBunu 3-4 kez tekrarla."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe in for 4 seconds, hold for 4, breathe out for 4.\nRepeat 3-4 times."
          }
        }
      }
    },
    "break.suggestion.walk.title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısa Bir Yürüyüş"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Short Walk"
          }
        }
      }
    },
    "break.suggestion.walk.description": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masandan kalk ve birkaç adım at.\nKan dolaşımını artır."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get up from your desk and take a few steps.\nImprove your blood circulation."
          }
        }
      }
    },
    "break.suggestion.water.title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Su İç"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drink Water"
          }
        }
      }
    },
    "break.suggestion.water.description": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir bardak su iç.\nHidrasyon odaklanmayı artırır."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Have a glass of water.\nHydration improves focus."
          }
        }
      }
    },
    "break.suggestion.eyes.title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gözlerini Dinlendir"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rest Your Eyes"
          }
        }
      }
    },
    "break.suggestion.eyes.description": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "20 saniye boyunca 20 metre uzağa bak.\nEkran yorgunluğunu azalt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look at something 20 meters away for 20 seconds.\nReduce screen fatigue."
          }
        }
      }
    },
    "break.suggestion.window.title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pencereden Dışarı Bak"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look Out the Window"
          }
        }
      }
    },
    "break.suggestion.window.description": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğaya veya gökyüzüne bak.\nZihnini tazele."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look at nature or the sky.\nRefresh your mind."
          }
        }
      }
    },
    "break.suggestion.stretch.title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Germe Hareketleri"
