    "language.restart_note": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçimin, uygulamayı bir sonraki açışında etkinleşecek."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your selection will take effect the next time you open the app."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيصبح اختيارك ساريًا عند فتح التطبيق في المرة القادمة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Auswahl wird beim nächsten Öffnen der App wirksam."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu selección se aplicará la próxima vez que abras la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre choix prendra effet à la prochaine ouverture de l'app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका चयन अगली बार ऐप खोलने पर लागू होगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilihanmu akan berlaku saat aplikasi dibuka lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua scelta avrà effetto alla prossima apertura dell'app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した言語は次回アプリを開いたときに適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 언어는 다음에 앱을 열 때 적용됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je keuze wordt van kracht wanneer je de app opnieuw opent."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybór zacznie obowiązywać przy następnym uruchomieniu aplikacji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua escolha entrará em vigor na próxima vez que você abrir o app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбор вступит в силу при следующем запуске приложения."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเลือกของคุณจะมีผลเมื่อเปิดแอปครั้งถัดไป"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вибір набуде чинності під час наступного запуску застосунку."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lựa chọn của bạn sẽ có hiệu lực vào lần mở ứng dụng tiếp theo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的选择将在下次打开应用时生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的選擇將在下次開啟 App 時生效。"
          }
        }
      }
    },
