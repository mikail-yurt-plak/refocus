    "friends.invite.error_lookup": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu numarayla bir Apple/iCloud hesabı bulunamadı. Numarayı ülke koduyla yazmayı dener misin?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn't find an Apple/iCloud account with this number. Could you try entering it with the country code?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم نعثر على حساب Apple/iCloud بهذا الرقم. هل يمكنك تجربة كتابة الرقم مع رمز الدولة؟"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit dieser Nummer wurde kein Apple/iCloud-Account gefunden. Magst du die Nummer einmal mit Ländervorwahl eingeben?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No encontramos una cuenta de Apple/iCloud con este número. ¿Puedes probar a escribirlo con el código de país?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun compte Apple/iCloud n'a été trouvé avec ce numéro. Peux-tu essayer de le saisir avec l'indicatif du pays ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस नंबर से कोई Apple/iCloud खाता नहीं मिला। क्या आप नंबर देश कोड के साथ लिखकर देखेंगे?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akun Apple/iCloud dengan nomor ini tidak ditemukan. Bisa coba tulis nomornya dengan kode negara?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non abbiamo trovato un account Apple/iCloud con questo numero. Puoi provare a inserirlo con il prefisso internazionale?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この番号のApple/iCloudアカウントが見つかりませんでした。国番号を付けて入力してみてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 번호로 등록된 Apple/iCloud 계정을 찾을 수 없어요. 국가 코드를 붙여서 다시 입력해 보시겠어요?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We konden geen Apple/iCloud-account met dit nummer vinden. Wil je het nummer eens met landcode proberen?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie znaleźliśmy konta Apple/iCloud z tym numerem. Możesz spróbować wpisać numer z kodem kraju?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não encontramos uma conta Apple/iCloud com este número. Pode tentar digitar o número com o código do país?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аккаунт Apple/iCloud с этим номером не найден. Попробуй, пожалуйста, ввести номер с кодом страны."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่พบบัญชี Apple/iCloud ที่ใช้หมายเลขนี้ ลองพิมพ์หมายเลขพร้อมรหัสประเทศดูได้ไหม"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Обліковий запис Apple/iCloud із цим номером не знайдено. Спробуй, будь ласка, ввести номер із кодом країни."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không tìm thấy tài khoản Apple/iCloud với số này. Bạn thử nhập số kèm mã quốc gia nhé?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有找到使用此号码的 Apple/iCloud 账户。可以试试加上国家代码再输入吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到使用此號碼的 Apple/iCloud 帳號。可以試著加上國碼再輸入嗎？"
          }
        }
      }
    },
    "friends.invite.channel_note": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Davet e-postayla gönderilmez — linki WhatsApp, Mesajlar veya dilediğin uygulamayla kendin paylaşırsın."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The invite isn't sent by email — you share the link yourself via WhatsApp, Messages, or any app you like."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تُرسل الدعوة عبر البريد الإلكتروني — أنت من يشارك الرابط عبر واتساب أو الرسائل أو أي تطبيق تريده."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Einladung wird nicht per E-Mail verschickt — du teilst den Link selbst über WhatsApp, Nachrichten oder eine App deiner Wahl."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La invitación no se envía por correo — tú mismo compartes el enlace por WhatsApp, Mensajes o la app que prefieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'invitation n'est pas envoyée par e-mail — tu partages toi-même le lien via WhatsApp, Messages ou l'app de ton choix."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आमंत्रण ईमेल से नहीं भेजा जाता — आप लिंक खुद WhatsApp, Messages या किसी भी ऐप से साझा करते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Undangan tidak dikirim lewat email — kamu sendiri yang membagikan tautannya lewat WhatsApp, Pesan, atau aplikasi apa pun."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'invito non viene inviato via email — sei tu a condividere il link tramite WhatsApp, Messaggi o l'app che preferisci."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "招待はメールでは送信されません。リンクはWhatsAppやメッセージなど、お好きなアプリからあなた自身で共有します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "초대는 이메일로 전송되지 않아요 — 링크는 WhatsApp, 메시지 등 원하는 앱에서 직접 공유하면 돼요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De uitnodiging wordt niet per e-mail verstuurd — je deelt de link zelf via WhatsApp, Berichten of een app naar keuze."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaproszenie nie jest wysyłane e-mailem — link udostępniasz samodzielnie przez WhatsApp, Wiadomości lub dowolną aplikację."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O convite não é enviado por e-mail — você mesmo compartilha o link pelo WhatsApp, Mensagens ou o app que preferir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приглашение не отправляется по почте — ссылкой ты делишься самостоятельно через WhatsApp, «Сообщения» или любое другое приложение."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำเชิญจะไม่ถูกส่งทางอีเมล — คุณแชร์ลิงก์เองผ่าน WhatsApp, ข้อความ หรือแอปไหนก็ได้ที่ต้องการ"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запрошення не надсилається електронною поштою — посиланням ти ділишся самостійно через WhatsApp, «Повідомлення» або будь-який інший застосунок."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lời mời không được gửi qua email — bạn tự chia sẻ liên kết qua WhatsApp, Tin nhắn hoặc bất kỳ ứng dụng nào bạn thích."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邀请不会通过电子邮件发送——链接由你自己通过 WhatsApp、信息或任意应用分享。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "邀請不會透過電子郵件傳送——連結由你自己透過 WhatsApp、訊息或任何 App 分享。"
          }
        }
      }
    },
    "friends.invite.ready_note": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Davet hazır — linki istediğin uygulamadan gönderebilirsin. Bu link yalnızca davet ettiğin kişi için çalışır."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invite ready — you can send the link from any app you like. This link only works for the person you invited."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الدعوة جاهزة — يمكنك إرسال الرابط من أي تطبيق تريده. هذا الرابط يعمل فقط للشخص الذي دعوته."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Einladung ist bereit — du kannst den Link über eine beliebige App senden. Dieser Link funktioniert nur für die Person, die du eingeladen hast."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La invitación está lista — puedes enviar el enlace desde la app que prefieras. Este enlace solo funciona para la persona que invitaste."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'invitation est prête — tu peux envoyer le lien depuis l'app de ton choix. Ce lien ne fonctionne que pour la personne que tu as invitée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आमंत्रण तैयार है — आप लिंक किसी भी ऐप से भेज सकते हैं। यह लिंक केवल उसी व्यक्ति के लिए काम करेगा जिसे आपने आमंत्रित किया है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Undangan siap — kamu bisa mengirim tautannya lewat aplikasi apa pun. Tautan ini hanya berfungsi untuk orang yang kamu undang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'invito è pronto — puoi inviare il link dall'app che preferisci. Questo link funziona solo per la persona che hai invitato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "招待の準備ができました。リンクはお好きなアプリから送れます。このリンクは招待した相手にだけ有効です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "초대가 준비됐어요 — 원하는 앱에서 링크를 보낼 수 있어요. 이 링크는 초대한 사람에게만 작동해요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De uitnodiging is klaar — je kunt de link via elke app versturen. Deze link werkt alleen voor de persoon die je hebt uitgenodigd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaproszenie gotowe — link możesz wysłać z dowolnej aplikacji. Ten link działa tylko dla zaproszonej przez Ciebie osoby."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Convite pronto — você pode enviar o link pelo app que preferir. Este link só funciona para a pessoa que você convidou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приглашение готово — ссылку можно отправить из любого приложения. Эта ссылка работает только для приглашённого человека."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำเชิญพร้อมแล้ว — คุณส่งลิงก์ผ่านแอปไหนก็ได้ ลิงก์นี้ใช้ได้เฉพาะกับคนที่คุณเชิญเท่านั้น"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запрошення готове — посилання можна надіслати з будь-якого застосунку. Це посилання працює лише для запрошеної людини."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lời mời đã sẵn sàng — bạn có thể gửi liên kết qua bất kỳ ứng dụng nào. Liên kết này chỉ hoạt động với người mà bạn đã mời."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邀请已就绪，你可以通过任意应用发送链接。此链接仅对你邀请的人有效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "邀請已準備好，你可以透過任何 App 傳送連結。此連結僅對你邀請的人有效。"
          }
        }
      }
    },
