    "feedback.note_description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ملاحظة قصيرة توفر الإغلاق الذهني وتساعدك على تذكر ما فعلته."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine kurze Notiz sorgt für mentalen Abschluss und hilft dir zu erinnern, was du getan hast."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A short note provides mental closure and helps you remember what you did."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una nota corta proporciona cierre mental y te ayuda a recordar lo que hiciste."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une courte note aide à la fermeture mentale et vous rappelle ce que vous avez fait."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक छोटा नोट मानसिक समापन प्रदान करता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Catatan singkat memberikan penutupan mental dan membantu mengingat apa yang kamu lakukan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una breve nota fornisce chiusura mentale e ti aiuta a ricordare cosa hai fatto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "短いメモは心理的な区切りになり、何をしたか思い出すのに役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "짧은 메모는 정신적 마무리를 제공하고 무엇을 했는지 기억하는 데 도움이 됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een korte notitie zorgt voor mentale afsluiting en helpt je herinneren wat je deed."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Krótka notatka zapewnia mentalne zamknięcie i pomaga zapamiętać, co zrobiłeś."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma nota curta proporciona fechamento mental e ajuda a lembrar o que você fez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткая заметка обеспечивает ментальное завершение и помогает вспомнить, что вы делали."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โน้ตสั้นๆ ช่วยปิดท้ายทางจิตใจและช่วยให้คุณจำได้ว่าทำอะไร"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısa bir not bırakmak, zihinsel kapanış sağlar ve geçmişe bakınca ne yaptığını hatırlatır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коротка нотатка забезпечує ментальне завершення і допомагає згадати, що ви робили."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ghi chú ngắn giúp kết thúc tinh thần và nhớ lại những gì bạn đã làm."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "简短的笔记能帮助你做好心理收尾，并回顾自己做了什么。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "簡短的筆記能幫助你做好心理收尾，並回顧自己做了什麼。"
          }
        }
      }
    },
