    "heatmap.empty_description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد إكمال بعض الجلسات\nستظهر هنا رسوم بيانية جميلة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach ein paar Sitzungen\nsiehst du hier eine schöne Visualisierung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After completing a few sessions\nyou'll see a nice visualization here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Después de completar algunas sesiones\nverás una bonita visualización aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après avoir terminé quelques sessions\ntu verras une belle visualisation ici."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ सत्र पूरे करने के बाद\nआपको यहाँ सुंदर विज़ुअलाइज़ेशन दिखाई देगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Setelah menyelesaikan beberapa sesi\nAnda akan melihat visualisasi yang bagus di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dopo aver completato alcune sessioni\nvedrai una bella visualizzazione qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いくつかのセッションを完了すると\nここにきれいな可視化が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "몇 세션을 완료하면\n여기에 멋진 시각화가 표시됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na het voltooien van een paar sessies\nzie je hier een mooie visualisatie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Po ukończeniu kilku sesji\nzobaczysz tu ładną wizualizację."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Após completar algumas sessões\nvocê verá uma bela visualização aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "После завершения нескольких сессий\nздесь появится красивая визуализация."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หลังจากทำเซสชันสักสองสามครั้ง\nคุณจะเห็นกราฟสวยๆ ที่นี่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Birkaç seans tamamladıktan sonra\nburada güzel bir görselleştirme olacak."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Після завершення кількох сеансів\nтут з'явиться гарна візуалізація."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sau khi hoàn thành vài phiên\nbạn sẽ thấy biểu đồ đẹp ở đây."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成几个会话后\n这里将显示漂亮的可视化图表。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "完成幾個會話後\n這裡將顯示漂亮的視覺化圖表。"
          }
        }
      }
    },
