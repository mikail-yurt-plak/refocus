    "onboarding.summary.hint": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنحسن توصياتنا باستمرار\nبناءً على استخدامك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir werden unsere Empfehlungen\nbasierend auf deiner Nutzung kontinuierlich verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll continuously improve\nour recommendations based on your usage."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejoraremos continuamente\nnuestras recomendaciones según tu uso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous améliorerons continuellement\nnos recommandations selon votre utilisation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम आपके उपयोग के आधार पर\nअपनी सिफारिशों में सुधार करते रहेंगे।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kami akan terus meningkatkan\nrekomendasi kami berdasarkan penggunaanmu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Miglioreremo continuamente\ni nostri consigli in base al tuo utilizzo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "使用状況に基づいて\n推奨を継続的に改善します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용 패턴에 따라\n추천을 지속적으로 개선하겠습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We zullen onze aanbevelingen\ncontinu verbeteren op basis van je gebruik."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Będziemy stale ulepszać\nnasze rekomendacje na podstawie twojego użycia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos melhorar continuamente\nnossas recomendações com base no seu uso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы будем постоянно улучшать\nнаши рекомендации на основе вашего использования."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เราจะปรับปรุงคำแนะนำ\nอย่างต่อเนื่องตามการใช้งานของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanımına göre önerilerimizi\nsürekli iyileştireceğiz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми постійно покращуватимемо\nнаші рекомендації на основі вашого використання."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
