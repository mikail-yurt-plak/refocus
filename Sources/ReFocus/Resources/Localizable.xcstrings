    "method.description.pomodoro": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısa, yoğun odak seansları. Sık mola alarak enerjini taze tut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Short, intense focus sessions. Stay energized with frequent breaks."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "短暂而专注的工作时段。通过频繁休息保持精力充沛。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "短暫而專注的工作時段。透過頻繁休息保持精力充沛。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "छोटे, गहन फोकस सत्र। बार-बार ब्रेक लेकर ऊर्जावान रहें।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesiones cortas e intensas de concentración. Mantén tu energía con descansos frecuentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessions courtes et intenses. Restez énergisé avec des pauses fréquentes."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جلسات تركيز قصيرة ومكثفة. حافظ على نشاطك مع فترات راحة متكررة."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessões curtas e intensas de foco. Mantenha sua energia com pausas frequentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткие интенсивные сессии фокусировки. Сохраняйте энергию с частыми перерывами."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "短く集中的なセッション。頻繁な休憩でエネルギーを保ちましょう。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurze, intensive Fokus-Sitzungen. Bleiben Sie mit häufigen Pausen energiegeladen."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "짧고 집중적인 포커스 세션. 자주 휴식을 취해 에너지를 유지하세요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các phiên tập trung ngắn và căng thẳng. Duy trì năng lượng với các lần nghỉ thường xuyên."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessioni di concentrazione brevi e intense. Mantieni l'energia con pause frequenti."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Krótkie, intensywne sesje skupienia. Zachowaj energię dzięki częstym przerwom."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткі інтенсивні сесії фокусування. Зберігайте енергію з частими перервами."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesi fokus singkat dan intens. Tetap berenergi dengan istirahat yang sering."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Korte, intense focussessies. Blijf energiek met frequente pauzes."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เซสชันโฟกัสสั้นๆ แต่เข้มข้น รักษาพลังงานด้วยการพักบ่อยๆ"
          }
        }
      }
    },
    "method.description.extended": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pomodoro'dan biraz daha uzun. Daha derinlemesine odaklanmak için."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A bit longer than Pomodoro. For deeper focus work."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "比番茄工作法稍长。适合更深入的专注工作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "比番茄工作法稍長。適合更深入的專注工作。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पोमोडोरो से थोड़ा लंबा। गहरे फोकस कार्य के लिए।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un poco más largo que Pomodoro. Para un enfoque más profundo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un peu plus long que Pomodoro. Pour une concentration plus profonde."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أطول قليلاً من بومودورو. للتركيز العميق."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um pouco mais longo que o Pomodoro. Para um foco mais profundo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Немного дольше Помодоро. Для более глубокой работы."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ポモドーロより少し長め。より深い集中作業に。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas länger als Pomodoro. Für tiefere Fokusarbeit."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "포모도로보다 약간 더 깁니다. 더 깊은 집중 작업을 위해."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dài hơn Pomodoro một chút. Để tập trung sâu hơn."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un po' più lungo del Pomodoro. Per un lavoro di concentrazione più profondo."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Trochę dłużej niż Pomodoro. Do głębszej pracy skupienia."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Трохи довше за Помодоро. Для глибшої зосередженої роботи."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sedikit lebih lama dari Pomodoro. Untuk pekerjaan fokus yang lebih dalam."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Iets langer dan Pomodoro. Voor dieper focuswerk."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยาวกว่าโปโมโดโรเล็กน้อย สำหรับงานที่ต้องโฟกัสลึกขึ้น"
          }
        }
      }
    },
    "method.description.optimal": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Araştırmalara göre optimal odak süresi. Dengeli ve sürdürülebilir."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Research-backed optimal focus duration. Balanced and sustainable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "研究支持的最佳专注时长。平衡且可持续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "研究支持的最佳專注時長。平衡且可持續。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शोध-समर्थित इष्टतम फोकस अवधि। संतुलित और टिकाऊ।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Duración de enfoque óptima respaldada por investigaciones. Equilibrada y sostenible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée de concentration optimale basée sur la recherche. Équilibrée et durable."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدة تركيز مثالية مدعومة بالأبحاث. متوازنة ومستدامة."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Duração de foco ideal baseada em pesquisas. Equilibrada e sustentável."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оптимальная продолжительность по исследованиям. Сбалансированная и устойчивая."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "研究に基づく最適な集中時間。バランスが取れて持続可能。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Forschungsgestützte optimale Fokuszeit. Ausgewogen und nachhaltig."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연구 기반의 최적 집중 시간. 균형 잡히고 지속 가능합니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thời lượng tập trung tối ưu theo nghiên cứu. Cân bằng và bền vững."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Durata di concentrazione ottimale basata sulla ricerca. Equilibrata e sostenibile."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Optymalny czas skupienia poparty badaniami. Zrównoważony i trwały."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Оптимальна тривалість за дослідженнями. Збалансована та стійка."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Durasi fokus optimal berdasarkan penelitian. Seimbang dan berkelanjutan."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door onderzoek ondersteunde optimale focusduur. Gebalanceerd en duurzaam."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ระยะเวลาโฟกัสที่เหมาะสมจากการวิจัย สมดุลและยั่งยืน"
          }
        }
      }
    },
    "method.description.deep_work": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kesintisiz derin çalışma. Karmaşık görevler için ideal."
          }
        },
