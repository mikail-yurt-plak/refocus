      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Have a glass of water.\nHydration improves focus."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir bardak su iç.\nHidrasyon odaklanmayı artırır."
          }
        }
      }
    },
