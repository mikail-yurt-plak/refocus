      }
    },
    "method.description.pomodoro": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جلسات تركيز قصيرة ومكثفة. حافظ على نشاطك مع فترات راحة متكررة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurze, intensive Fokus-Sitzungen. Bleiben Sie mit häufigen Pausen energiegeladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Short, intense focus sessions. Stay energized with frequent breaks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesiones cortas e intensas de concentración. Mantén tu energía con descansos frecuentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessions courtes et intenses. Restez énergisé avec des pauses fréquentes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "छोटे, गहन फोकस सत्र। बार-बार ब्रेक लेकर ऊर्जावान रहें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesi fokus singkat dan intens. Tetap berenergi dengan istirahat yang sering."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessioni di concentrazione brevi e intense. Mantieni l'energia con pause frequenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "短く集中的なセッション。頻繁な休憩でエネルギーを保ちましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "짧고 집중적인 포커스 세션. 자주 휴식을 취해 에너지를 유지하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Korte, intense focussessies. Blijf energiek met frequente pauzes."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Krótkie, intensywne sesje skupienia. Zachowaj energię dzięki częstym przerwom."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessões curtas e intensas de foco. Mantenha sua energia com pausas frequentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткие интенсивные сессии фокусировки. Сохраняйте энергию с частыми перерывами."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เซสชันโฟกัสสั้นๆ แต่เข้มข้น รักษาพลังงานด้วยการพักบ่อยๆ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısa, yoğun odak seansları. Sık mola alarak enerjini taze tut."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткі інтенсивні сесії фокусування. Зберігайте енергію з частими перервами."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các phiên tập trung ngắn và căng thẳng. Duy trì năng lượng với các lần nghỉ thường xuyên."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "短暂而专注的工作时段。通过频繁休息保持精力充沛。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "短暫而專注的工作時段。透過頻繁休息保持精力充沛。"
          }
        }
      }
