        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لاستخدام هذه الميزة، يجب أن تكون مسجّل الدخول إلى حساب iCloud الخاص بك."
          }
        },
        "de": {
          "stringUnit": {
