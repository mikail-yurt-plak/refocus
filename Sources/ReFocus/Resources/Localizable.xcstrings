        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yarın yeni bir gün. Küçük adımlarla başla."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tomorrow is a new day. Start with small steps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "明天是新的一天。从小步骤开始。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "明天是新的一天。從小步驟開始。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कल नया दिन है। छोटे कदमों से शुरू करें।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mañana es un nuevo día. Empieza con pasos pequeños."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demain est un nouveau jour. Commence par de petits pas."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غداً يوم جديد. ابدأ بخطوات صغيرة."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Amanhã é um novo dia. Comece com pequenos passos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Завтра — новый день. Начни с маленьких шагов."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "明日は新しい日。小さな一歩から始めよう。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Morgen ist ein neuer Tag. Fang mit kleinen Schritten an."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내일은 새로운 날이에요. 작은 걸음부터 시작하세요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngày mai là một ngày mới. Bắt đầu bằng những bước nhỏ."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Domani è un nuovo giorno. Inizia con piccoli passi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jutro to nowy dzień. Zacznij od małych kroków."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Завтра — новий день. Почни з маленьких кроків."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Besok hari baru. Mulai dengan langkah kecil."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Morgen is een nieuwe dag. Begin met kleine stappen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "พรุ่งนี้คือวันใหม่ เริ่มจากก้าวเล็กๆ"
          }
        }
      }
    },
