    "friends.viewers.remove_confirm": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu kişi artık özetini göremeyecek. Devam edilsin mi?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This person will no longer be able to see your summary. Continue?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يتمكن هذا الشخص من رؤية ملخصك بعد الآن. هل تريد المتابعة؟"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Person kann deine Zusammenfassung dann nicht mehr sehen. Fortfahren?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta persona ya no podrá ver tu resumen. ¿Quieres continuar?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette personne ne pourra plus voir ton résumé. Continuer ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह व्यक्ति अब आपका सारांश नहीं देख पाएगा। क्या आगे बढ़ें?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
