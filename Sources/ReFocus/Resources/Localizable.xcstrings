    "intent.description.mixed": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "في الوضع المختلط، الفترات التي تزيد عن 60 ثانية تعتبر انقطاعات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im gemischten Modus zählen Pausen über 60 Sekunden als Unterbrechungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In mixed mode, breaks longer than 60 seconds count as interruptions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En modo mixto, pausas mayores a 60 segundos cuentan como interrupciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En mode mixte, les pauses de plus de 60 secondes comptent comme interruptions."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मिश्रित मोड में 60 सेकंड से अधिक का ब्रेक व्यवधान माना जाता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dalam mode campuran, jeda lebih dari 60 detik dihitung sebagai gangguan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In modalità mista, pause superiori a 60 secondi contano come interruzioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ミックスモードでは60秒以上の離脱は中断としてカウントされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "혼합 모드에서는 60초 이상 이탈 시 방해로 집계됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "In gemengde modus tellen pauzes langer dan 60 seconden als onderbrekingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W trybie mieszanym przerwy dłuższe niż 60 sekund liczą się jako przerwania."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "No modo misto, pausas maiores que 60 segundos contam como interrupções."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В смешанном режиме перерывы более 60 секунд считаются прерываниями."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ในโหมดผสม การหยุดพักเกิน 60 วินาทีนับเป็นการขัดจังหวะ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Karışık modda 60 saniyeden uzun ayrılmalar bölünme sayılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "У змішаному режимі перерви понад 60 секунд вважаються перериваннями."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trong chế độ hỗn hợp, nghỉ hơn 60 giây được tính là gián đoạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在混合模式下，超过60秒的离开将计为中断。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在混合模式下，超過60秒的離開將計為中斷。"
          }
        }
      }
    },
    "intent.description.reading": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "في وضع القراءة/الكتابة، الفترات التي تزيد عن 30 ثانية تعتبر انقطاعات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im Lese-/Schreibmodus zählen Pausen über 30 Sekunden als Unterbrechungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In reading/writing mode, breaks longer than 30 seconds count as interruptions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En modo lectura/escritura, pausas mayores a 30 segundos cuentan como interrupciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En mode lecture/écriture, les pauses de plus de 30 secondes comptent comme interruptions."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पढ़ने/लिखने मोड में 30 सेकंड से अधिक का ब्रेक व्यवधान माना जाता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dalam mode membaca/menulis, jeda lebih dari 30 detik dihitung sebagai gangguan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In modalità lettura/scrittura, pause superiori a 30 secondi contano come interruzioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み書きモードでは30秒以上の離脱は中断としてカウントされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "읽기/쓰기 모드에서는 30초 이상 이탈 시 방해로 집계됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "In lees-/schrijfmodus tellen pauzes langer dan 30 seconden als onderbrekingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W trybie czytania/pisania przerwy dłuższe niż 30 sekund liczą się jako przerwania."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "No modo leitura/escrita, pausas maiores que 30 segundos contam como interrupções."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В режиме чтения/письма перерывы более 30 секунд считаются прерываниями."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ในโหมดอ่าน/เขียน การหยุดพักเกิน 30 วินาทีนับเป็นการขัดจังหวะ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Okuma/yazma modunda 30 saniyeden uzun ayrılmalar bölünme sayılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "У режимі читання/письма перерви понад 30 секунд вважаються перериваннями."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trong chế độ đọc/viết, nghỉ hơn 30 giây được tính là gián đoạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读/写作模式下，超过30秒的离开将计为中断。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在閱讀/寫作模式下，超過30秒的離開將計為中斷。"
          }
        }
      }
    },
    "intent.description.watching": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "في وضع مشاهدة الفيديو، التنقلات القصيرة تعتبر طبيعية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im Videomodus gelten kurze Wechsel als normal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In video watching mode, short transitions are considered normal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En modo video, las transiciones cortas se consideran normales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En mode vidéo, les transitions courtes sont considérées normales."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वीडियो देखने के मोड में छोटे बदलाव सामान्य माने जाते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dalam mode menonton video, perpindahan singkat dianggap normal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In modalità video, le transizioni brevi sono considerate normali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "動画視聴モードでは短い切り替えは正常とみなされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비디오 시청 모드에서는 짧은 전환이 정상으로 간주됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "In videomodus worden korte overgangen als normaal beschouwd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W trybie wideo krótkie przejścia są uznawane za normalne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "No modo vídeo, transições curtas são consideradas normais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В режиме просмотра видео короткие переключения считаются нормальными."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ในโหมดดูวิดีโอ การสลับสั้นๆ ถือเป็นเรื่องปกติ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Video izleme modunda kısa geçişler normal kabul edilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "У режимі перегляду відео короткі переходи вважаються нормальними."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trong chế độ xem video, chuyển đổi ngắn được coi là bình thường."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在视频观看模式下，短暂切换被认为是正常的。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在影片觀看模式下，短暫切換被認為是正常的。"
          }
        }
      }
    },
