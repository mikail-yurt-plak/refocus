    "break.suggestion.walk.description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get up from your desk and take a few steps.\nImprove your blood circulation."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masandan kalk ve birkaç adım at.\nKan dolaşımını artır."
          }
        }
      }
    },
    "break.suggestion.walk.title": {
