    "friends.setup.description": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkadaşlarınla günlük odak özetlerinizi paylaşabilirsiniz. Kimin daha çok çalıştığı yarışması yok — sadece birlikte çalışmanın motivasyonu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can share your daily focus summaries with friends. There's no contest over who worked more — just the motivation of working together."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك مشاركة ملخصات تركيزك اليومية مع أصدقائك. لا منافسة على من عمل أكثر — فقط دافع العمل معًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst deine täglichen Fokus-Zusammenfassungen mit Freunden teilen. Es gibt keinen Wettbewerb, wer mehr gearbeitet hat – nur die Motivation, gemeinsam zu arbeiten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes compartir tus resúmenes diarios de enfoque con tus amigos. No hay competencia por quién trabajó más: solo la motivación de trabajar juntos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez partager vos résumés de concentration quotidiens avec vos amis. Aucune compétition pour savoir qui a travaillé le plus — juste la motivation de travailler ensemble."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप अपने दोस्तों के साथ अपनी दैनिक फोकस समरी साझा कर सकते हैं। कौन ज़्यादा काम करता है, इसकी कोई होड़ नहीं — बस साथ मिलकर काम करने की प्रेरणा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu bisa berbagi ringkasan fokus harian dengan teman-temanmu. Tidak ada lomba siapa yang bekerja lebih banyak — hanya motivasi untuk bekerja bersama."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi condividere i tuoi riepiloghi giornalieri di focus con gli amici. Nessuna gara a chi lavora di più — solo la motivazione di lavorare insieme."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "友達と毎日の集中サマリーを共有できます。誰がより多く働いたかを競うものではなく、一緒に取り組むモチベーションのためのものです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "친구들과 매일의 집중 요약을 공유할 수 있어요. 누가 더 많이 일했는지 겨루는 게 아니라, 함께하는 동기부여를 위한 거예요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je kunt je dagelijkse focussamenvattingen met vrienden delen. Geen wedstrijd wie het meest heeft gewerkt — alleen de motivatie van samen werken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz dzielić się codziennymi podsumowaniami skupienia ze znajomymi. Bez rywalizacji o to, kto pracował więcej — tylko motywacja płynąca ze wspólnej pracy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode compartilhar seus resumos diários de foco com amigos. Não há competição sobre quem trabalhou mais — apenas a motivação de trabalhar juntos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете делиться с друзьями ежедневными сводками фокуса. Никакого соревнования, кто работал больше, — только мотивация работать вместе."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณสามารถแชร์สรุปการโฟกัสประจำวันกับเพื่อนได้ ไม่มีการแข่งขันว่าใครทำงานมากกว่า — มีเพียงแรงจูงใจจากการทำงานไปด้วยกัน"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете ділитися з друзями щоденними підсумками фокусу. Жодного змагання, хто працював більше, — лише мотивація працювати разом."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có thể chia sẻ tóm tắt tập trung hằng ngày với bạn bè. Không có cuộc thi xem ai làm việc nhiều hơn — chỉ là động lực cùng nhau làm việc."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以和朋友分享每日专注摘要。没有谁工作更多的比赛——只有一起努力的动力。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以和朋友分享每日專注摘要。沒有誰工作更多的比賽——只有一起努力的動力。"
          }
        }
      }
    },
    "friends.setup.privacy": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verilerin yalnızca senin ve davet ettiğin kişilerin iCloud hesapları arasında paylaşılır; hiçbir sunucuya gönderilmez."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data is shared only between your iCloud account and those of the people you invite; it is never sent to any server."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتم مشاركة بياناتك فقط بين حساب iCloud الخاص بك وحسابات الأشخاص الذين تدعوهم؛ ولا تُرسل إلى أي خادم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Daten werden nur zwischen deinem iCloud-Konto und denen der von dir eingeladenen Personen geteilt; sie werden an keinen Server gesendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus datos se comparten solo entre tu cuenta de iCloud y las de las personas que invites; no se envían a ningún servidor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos données ne sont partagées qu'entre votre compte iCloud et ceux des personnes que vous invitez ; elles ne sont envoyées à aucun serveur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका डेटा केवल आपके और आपके आमंत्रित लोगों के iCloud खातों के बीच साझा होता है; किसी सर्वर पर नहीं भेजा जाता।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Datamu hanya dibagikan antara akun iCloud milikmu dan milik orang yang kamu undang; tidak dikirim ke server mana pun."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi dati vengono condivisi solo tra il tuo account iCloud e quelli delle persone che inviti; non vengono inviati a nessun server."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データはあなたと招待した人のiCloudアカウント間でのみ共有され、サーバーには一切送信されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터는 나와 초대한 사람의 iCloud 계정 사이에서만 공유되며, 어떤 서버로도 전송되지 않아요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je gegevens worden alleen gedeeld tussen jouw iCloud-account en die van de mensen die je uitnodigt; ze worden naar geen enkele server verzonden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje dane są udostępniane wyłącznie między Twoim kontem iCloud a kontami zaproszonych osób; nie są wysyłane na żaden serwer."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seus dados são compartilhados apenas entre a sua conta do iCloud e as das pessoas que você convidar; nunca são enviados a nenhum servidor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши данные передаются только между вашей учётной записью iCloud и учётными записями приглашённых вами людей; они не отправляются ни на какой сервер."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้อมูลของคุณจะแชร์เฉพาะระหว่างบัญชี iCloud ของคุณกับของคนที่คุณเชิญเท่านั้น จะไม่ถูกส่งไปยังเซิร์ฟเวอร์ใด ๆ"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваші дані передаються лише між вашим обліковим записом iCloud та обліковими записами запрошених вами людей; вони не надсилаються на жодний сервер."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dữ liệu của bạn chỉ được chia sẻ giữa tài khoản iCloud của bạn và của những người bạn mời; không bao giờ được gửi đến bất kỳ máy chủ nào."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的数据仅在你和你邀请的人的 iCloud 账户之间共享，不会发送到任何服务器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的資料僅在你和你邀請的人的 iCloud 帳戶之間共享，不會傳送到任何伺服器。"
          }
        }
      }
    },
