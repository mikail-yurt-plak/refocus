    "feedback.note_hint": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısa bir not bırakmak, zihinsel kapanış sağlar ve geçmişe bakınca ne yaptığını hatırlatır."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
