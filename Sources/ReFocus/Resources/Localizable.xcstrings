        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "짧은 메모는 정신적 마무리를 제공하고 무엇을 했는지 기억하는 데 도움이 됩니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
