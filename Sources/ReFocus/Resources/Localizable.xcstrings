    "heatmap.encouragement.first_week": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlk haftanı tamamladın. Devam et!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You completed your first week. Keep going!"
          }
        }
      }
    },
    "heatmap.encouragement.improving": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geçen haftaya göre daha iyi odaklanıyorsun."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're focusing better than last week."
          }
        }
      }
    },
    "heatmap.encouragement.tough_week": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu hafta biraz daha zordu. Bu normal, herkesin böyle haftaları olur."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This week was a bit harder. That's normal, everyone has weeks like this."
          }
        }
      }
    },
    "heatmap.encouragement.stable": {
      "localizations": {
        "tr": {
          "stringUnit": {
