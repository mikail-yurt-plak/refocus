          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоб користуватися цією функцією, потрібно ввійти в обліковий запис iCloud."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn cần đăng nhập vào tài khoản iCloud để dùng tính năng này."
