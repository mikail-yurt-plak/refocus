    "friends.remove_confirm": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu arkadaşı listeden çıkarmak istiyor musun? Onun paylaşımını artık görmezsin."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Do you want to remove this friend from your list? You will no longer see what they share."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد إزالة هذا الصديق من قائمتك؟ لن ترى ما يشاركه بعد الآن."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchtest du diese Person aus deiner Liste entfernen? Was sie teilt, siehst du dann nicht mehr."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Quieres quitar a este amigo de tu lista? Ya no verás lo que comparte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous retirer cet ami de votre liste ? Vous ne verrez plus ce qu'il partage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या आप इस दोस्त को सूची से हटाना चाहते हैं? इसके बाद आप उसकी साझा की गई समरी नहीं देख पाएंगे।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apakah kamu ingin menghapus teman ini dari daftar? Kamu tidak akan lagi melihat apa yang dia bagikan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuoi rimuovere questo amico dall'elenco? Non vedrai più ciò che condivide."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この友達をリストから削除しますか？相手の共有内容は表示されなくなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 친구를 목록에서 제거할까요? 친구가 공유하는 내용을 더 이상 볼 수 없어요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wil je deze vriend uit je lijst verwijderen? Je ziet dan niet meer wat hij of zij deelt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy chcesz usunąć tego znajomego z listy? Nie będziesz już widzieć tego, co udostępnia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quer remover este amigo da sua lista? Você não verá mais o que ele compartilha."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Убрать этого друга из списка? Вы больше не будете видеть то, чем он делится."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ต้องการนำเพื่อนคนนี้ออกจากรายชื่อหรือไม่ คุณจะไม่เห็นสิ่งที่เขาแชร์อีกต่อไป"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прибрати цього друга зі списку? Ви більше не бачитимете те, чим він ділиться."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có muốn xóa người bạn này khỏi danh sách không? Bạn sẽ không còn thấy những gì họ chia sẻ nữa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要将这位朋友从列表中移除吗？之后你将不再看到对方分享的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "要將這位朋友從列表中移除嗎？之後你將不再看到對方分享的內容。"
          }
        }
      }
    },
    "friends.icloud_required": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu özellik için iCloud hesabında oturum açmış olman gerekiyor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You need to be signed in to your iCloud account to use this feature."
