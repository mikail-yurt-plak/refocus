    "onboarding.context_description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك اختيار سياقات العمل لإضافة معنى لجلساتك.\nهذا اختياري تماماً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst Arbeitskontexte wählen, um deinen Sitzungen Bedeutung zu geben.\nDas ist völlig optional."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can choose work contexts to add meaning to your sessions.\nThis is completely optional."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes elegir contextos de trabajo para dar sentido a tus sesiones.\nEsto es completamente opcional."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez choisir des contextes de travail pour donner du sens à vos sessions.\nC'est complètement optionnel."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप अपने सत्रों में अर्थ जोड़ने के लिए कार्य संदर्भ चुन सकते हैं।\nयह पूरी तरह से वैकल्पिक है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu bisa memilih konteks kerja untuk memberi makna pada sesimu.\nIni sepenuhnya opsional."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi scegliere contesti di lavoro per dare significato alle tue sessioni.\nQuesto è completamente opzionale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションに意味を持たせるために作業コンテキストを選べます。\nこれは完全にオプションです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션에 의미를 더하기 위해 작업 컨텍스트를 선택할 수 있습니다.\n이것은 완전히 선택 사항입니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je kunt werkcontexten kiezen om betekenis te geven aan je sessies.\nDit is volledig optioneel."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz wybrać konteksty pracy, aby nadać znaczenie swoim sesjom.\nTo całkowicie opcjonalne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode escolher contextos de trabalho para dar significado às suas sessões.\nIsso é completamente opcional."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете выбрать рабочие контексты, чтобы придать смысл своим сессиям.\nЭто совершенно необязательно."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณสามารถเลือกบริบทการทำงานเพื่อเพิ่มความหมายให้กับเซสชันของคุณ\nนี่เป็นตัวเลือก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seanslarına anlam katmak için çalışma alanlarını seçebilirsin.\nBu tamamen opsiyonel."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете вибрати робочі контексти, щоб надати сенс своїм сесіям.\nЦе повністю необов'язково."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có thể chọn ngữ cảnh công việc để thêm ý nghĩa cho các phiên.\nĐiều này hoàn toàn tùy chọn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以选择工作场景来为专注时段增添意义。\n这完全是可选的。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以選擇工作場景來為專注時段增添意義。\n這完全是可選的。"
          }
        }
      }
    },
